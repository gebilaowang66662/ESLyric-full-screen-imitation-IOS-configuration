<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel layout="stack" name="Mini" orientation="vertical" features="1">

                <!-- 悬浮提示 -->
                <tooltip background-color= "rgba(255,255,255,0.1)"
                                font-size="10"/>

                <!-- 歌曲信息容器 -->
                <container name="toppane" width="100%"  height="100" orientation="horizonal" >

                                <!-- 上一曲按钮 -->
                                <button command="esl://Previous"
                                        height="100%"
                                        width="28"/>

                                <!-- 专辑封面容器 -->
                                <container name="albumart"  width="auto" height="100%" layout="free" >

                                        <!-- 专辑封面 -->
                                      <albumart width="auto"
                                                height="60%"
                                                aspect-ratio="1.0"
                                                stub="images/default.png"
                                                radius="10"
                                                use-stub="false"
                                                follow-background="1"
                                                shadow="1" 
                                                shadow-color="rgba(0,0,0,0.8)" 
                                                shadow-intensity="10"/>

                                        <!-- 播放/暂停按钮 -->
                                        <button command="esl://PlayOrPause"
                                                height="57%"
                                                width="auto"
                                                aspect-ratio="1.0"/>

                                </container>


                                <container name="meta-info"  width="*" height="100%" >

                                        <!-- 歌曲歌手标签 -->
                                        <container name="info"  width="100%" height="100%" justify="start">

                                                <!-- 顶部开关 -->
                                                <container name="open"  width="100%"  height="30%" orientation="horizonal" justify="end" margin-top="4%" margin-bottom="4%">

                                                        <!-- 全屏 -->
                                                        <button background="images/Fullscreen.png"
                                                                command="mm://${Fullscreen}"
                                                                width="auto"
                                                                height="80%"
                                                                aspect-ratio="1.0"/>

                                                        <!-- 关闭悬浮窗并打开主窗口 -->
                                                        <button background="images/Closeflowin.png"
                                                                command="mm://${Floating Lyric}"
                                                                margin-left="15"
                                                                width="auto"
                                                                height="80%"
                                                                aspect-ratio="1.0"/>


                                                </container>


                                                <!--  歌曲标题标签 
                                                        font-size 字号推荐大小
                                                        2K:  || 1080P:  || 720P:  -->
                                                <label  name="title"
                                                        caption="%title%"
                                                        text-align="left"
                                                        text-color="rgb(255,255,255)"
                                                        font-size="18"
                                                        width="auto"
                                                        height="auto"
                                                        anchor="left"
                                                        margin-left="15"
                                                        loop="cycle"
                                                        command="lib://%%album%% IS %album%"/>

                                                <!--  歌手标签 
                                                        font-size 字号推荐大小
                                                        2K:  || 1080P:  || 720P:   -->
                                                 <label name="artist"
                                                        margin-top="5%"
                                                        caption="[%artist%]"
                                                        text-align="left"
                                                        text-color="rgba(255,255,255,0.5)"
                                                        font-size="16"
                                                        width="auto"
                                                        height="auto"
                                                        anchor="left"
                                                        margin-left="15"
                                                        loop="cycle"
                                                        command="lib://%artist%"/>


                                        </container>


                        </container>

                                <!-- 下一曲按钮 -->
                                <button command="esl://Next"
                                        height="100%"
                                        width="28"/>


                </container>

                <container name="lyric"  width="100%" height="*" orientation="horizonal" >

                         <container name="lyric"  width="100%" height="*" orientation="horizonal" visibility="$ifequal(%esl_has_playing_lyric%,0,0,1)">

                                        <!-- 上一曲按钮 -->
                                        <button height="100%"
                                                width="28"/>

                                        <!-- 歌词面板 -->
                                        <lyric width="*"
                                               height="*"/>

                                        <!-- 上一曲按钮 -->
                                        <button height="100%"
                                                width="28"/>        

                        </container>    


                         <container name="visualization"  width="100%" height="*" orientation="horizonal" visibility="$ifequal(%esl_has_playing_lyric%,0,1,0)">

                                <!-- 占位按钮 -->
                                <button height="100%"
                                        width="85"/>

                                <!-- 
                                频谱 三种形态
                                classic/simple-bar/wave
                                -->
                                <visualization  type="spectrum"
                                                width="*"
                                                height="100%"
                                                max-height="150"
                                                anchor="center"

                                                spectrum="wave"

                                                mirror="1"              
                                                bands="60"
                                                segs="0"                   
                                                hi-color="rgba(255,255,255,1)"
                                                lo-color="rgba(255,255,255,0.5)"
                                                
                                                bar-color="rgba(255, 255, 255, 0.8)"  

                                                thickness="2"
                                                grow="2" 
                                                grow-radius="6"   
                                                back-color="rgba(255,255,255,0)" 
                                                back-outline-color="{HIGHLIGHT}" 
                                                front-color="rgba(255,255,255,0)" 
                                                front-outline-color="rgb(0, 162, 255)" />      

                                <!-- 占位按钮 -->
                                <button height="100%"
                                        width="90"/>


                        </container> 

                </container>




                <!-- 底部组件容器 -->
                <container name="bottom-panel"  width="100%"  height="50%" max-height="110" max-width="600" min-height="95" hide-min="1">

                       <!-- 播放时间显示 -->
                        <container name="length" orientation="horizontal" width="84%" height="auto" >

                                <!-- 当前播放时间 
                                font-size 字号推荐大小
                                2K:  || 1080P:  || 720P:   -->
                                <label name="playback_time"
                                        caption="%playback_time%"
                                        text-align="left"
                                        text-color="rgba(255,255,255,0.3)"
                                        font-size="16"
                                        width="auto"
                                        min-width="45"
                                        height="auto" />

                                <!-- 播放进度条 
                                track-height thumb-radius(同)推荐大小
                                2K:  || 1080P:  || 720P:   -->
                               <seekbar width="*"
                                        height="100%"
                                        track-height="7"
                                        thumb-radius="7"
                                        thumb-color="rgba(255,255,255,0.8)"
                                        foreground-color="rgba(255,255,255,0.8)"
                                        background-color="rgba(255,255,255,0.2)"
                                        radius="4"
                                        always-show-thumb="false"
                                        show-lyric-tooltip="true"
                                        free-seek="1"
                                        tooltip-padding="6"/>

                                <!-- 剩余播放时间 
                                font-size 字号推荐大小
                                2K:  || 1080P:  || 720P:   -->
                                <label  name="playback_time_remaining"
                                        caption="-%playback_time_remaining%"
                                        text-align="right"
                                        text-color="rgba(255,255,255,0.3)"
                                        font-size="16"
                                        width="auto"
                                        min-width="50"
                                        height="auto" />


                        </container>

                        <!-- 控制按钮组 -->
                        <container name="ctrl" orientation="horizontal" width="100%" height="80%" >

                                <!-- 随机模式按钮 通用数据-->
                                <props  id="Random" 
                                        height="57%"
                                        width="auto"
                                        aspect-ratio="1.0"
                                        margin-right="2%"/>

                                <!-- 随机播放/默认模式切换按钮 -->
                                <button props="Random"
                                        background="$if($or($ifequal(%fb2k_playback_order%,3,1,0),$ifequal(%fb2k_playback_order%,4,1,0),$ifequal(%fb2k_playback_order%,5,1,0)),images/Random.png,images/Random_Close.png)"
                                        command="esl://PlaybackOrderShuffleTracks"
                                        visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,1,1,$ifequal(%fb2k_playback_order%,2,1,0)))"/>

                                <button props="Random"
                                        background="images/Random.png"
                                        command="esl://PlaybackOrderDefault"
                                        visibility="$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0))))"/>


                                <!-- 播放按钮 通用数值 -->
                                <props  id="play" 
                                        height="57%"
                                        width="auto"
                                        aspect-ratio="1.0"/>

                                <!-- 上一曲按钮 -->
                                <button props="play"
                                        background="images/previous.png"
                                        command="esl://Previous"
                                        margin-right="2%"/>

                                <!-- 播放/暂停按钮 -->
                                <button props="play"
                                        background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                                        command="esl://PlayOrPause"/>

                                <!-- 下一曲按钮 -->
                                <button props="play"
                                        background="images/next.png"
                                        command="esl://Next"
                                        margin-left="2%"/>

                                <!-- 循环模式按钮 通用数据-->
                                <props  id="cycling" 
                                        height="57%"
                                        width="auto"
                                        aspect-ratio="1.0"
                                        margin-left="2%"/>

                                <!-- 循环模式按钮 -->
                                <button props="cycling"
                                        background="$if($or($ifequal(%fb2k_playback_order%,0,1,0),$ifequal(%fb2k_playback_order%,1,1,0),$ifequal(%fb2k_playback_order%,2,1,0)),images/Single loop.png,images/cycling_Close.png)"
                                        command="esl://PlaybackOrderRepeatPlaylist"
                                        visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0)))))"/>

                                <button props="cycling"
                                        background="images/cycling.png"
                                        command="esl://PlaybackOrderRepeatTrack"
                                        visibility="$ifequal(%fb2k_playback_order%,1,1,0)"/>

                                <button props="cycling"
                                        background="images/Single loop.png"
                                        command="esl://PlaybackOrderDefault"
                                        visibility="$ifequal(%fb2k_playback_order%,2,1,0)"/>


                        </container>


                </container>


  </panel>


</layout>