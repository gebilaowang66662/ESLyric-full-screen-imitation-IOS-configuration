<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel name="Mini 6" features="1" layout="free">

                <!-- 悬浮提示 -->
                <tooltip background-color= "rgba(255,255,255,0.1)"
                        text-color="rgb(0,0,0)"
                        font-size="10"/>



                <!-- 唱片机背景 -->
                <image  width="100%"
                        height="100%"
                        background="images/LP_background.png"
                        background-slice="1,1,1,1"/>

                <!-- 专辑封面 -->
              <albumart width="78%"
                        height="auto"
                        margin="0,2%,10%,0"
                        aspect-ratio="1.0"
                        radius="10"
                        rotate-speed="2"
                        stub="images/default.png"
                        use-stub="false"
                        follow-background="1"
                        shadow="1"
                        shadow-color="rgba(0,0,0,0.8)"
                        shadow-intensity="10"
                        mask="images/Record.png"
                        rotate="1"/>

                <!-- 歌手封面 -->
              <albumart width="6%"
                        height="auto"
                        margin="44%,0,0,7%"
                        aspect-ratio="1.0"
                        radius="10"
                        rotate-speed="1"
                        stub="images/default.png"
                        use-stub="ture"
                        album-art="artist"
                        shadow="1"
                        shadow-color="rgba(0,0,0,0.8)"
                        shadow-intensity="10"
                        mask="images/Record.png"
                        rotate="0"/>
                
                <!-- 唱臂 -->
                <button width="45%"
                        height="100%"
                        margin="28%,0,0,0"
                        background="$if($or($not(%isplaying%), %ispaused%),images/tone arm pause.png,images/tone arm play.png)"/>

                
                <!-- 上一曲按钮 -->
                <button background="images/previous.png"
                        command="esl://Previous"
                        width="10%"
                        height="auto"
                        margin="25%,40%,0,0"
                        aspect-ratio="1.0"/>

                <!-- 下一曲按钮 -->
                <button background="images/next.png"
                        command="esl://Next"
                        width="10%"
                        height="auto"
                        margin="44%,40%,0,0"
                        aspect-ratio="1.0"/>
                

                <!-- 播放/暂停按钮 -->
                <button background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                        command="esl://PlayOrPause"
                        width="8%"
                        height="auto"
                        margin="0,40%,42%,0"
                        aspect-ratio="1.0"/>

                <!--  歌曲标题标签 
                                font-size 字号推荐大小
                                2K:  || 1080P:  || 720P:  -->
                 <label name="title"
                        caption="%title%"
                        text-align="right"
                        margin="36%,23%,0,0"
                        text-color="rgb(255,255,255)"
                        highlight-color="rgb(255,255,255)"
                        font-size="16"
                        width="21%"
                        height="auto"
                        loop="cycle"
                        command="lib://%%album%% IS %album%"/>
                
                
                <!--  歌手标签 
                                font-size 字号推荐大小
                                2K:  || 1080P:  || 720P:   -->
                 <label name="artist"
                        margin="34%,30%,0,0"
                        caption="[%artist%]"
                        text-align="right"
                        text-color="rgba(255,255,255,0.5)"
                        highlight-color="rgb(255,255,255)"
                        font-size="14"
                        width="25%"
                        height="auto"
                        loop="cycle"
                        command="lib://%artist%"/>

                <!-- 关闭悬浮窗 -->
                <button anchor="top,left"
                        command="mm://${Floating Lyric}"
                        width="25%"
                        height="10%"/>
                
                <!-- 歌词面板 -->
                 <lyric width="88%"
                        height="*"
                        hide-empty="1"
                        visibility="0"/>

  </panel>


</layout>