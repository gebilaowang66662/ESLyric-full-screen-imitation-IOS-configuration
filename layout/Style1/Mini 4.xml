<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel name="Mini 4" features="1" >

                <!-- 悬浮提示 -->
                <tooltip background-color= "rgba(255,255,255,0.1)"
                        text-color="rgb(0,0,0)"
                        font-size="10"/>
                
                <!-- 专辑封面容器 -->
                <container name="albumart"  width="100%" height="70%" layout="free" >

                        <container name="albumart"  width="100%" height="100%" orientation="horizonal">

                                <!-- 专辑封面 -->
                              <albumart width="auto"
                                        height="80%"
                                        aspect-ratio="1.0"
                                        radius="10"
                                        rotate-speed="1"
                                        stub="images/default.png"
                                        use-stub="false"
                                        follow-background="1"
                                        shadow="1"
                                        shadow-color="rgba(0,0,0,0.8)"
                                        shadow-intensity="10"
                                        mask="images/Record.png"
                                        rotate="1"/>
                        
                        


                                <!-- 
                                频谱 三种形态
                                classic/simple-bar/wave
                                -->
                                 <visualization type="spectrum"
                                                width="3%"
                                                height="70%"
                                                margin-left="10%"

                                                spectrum="wave"

                                                mirror="0"              
                                                bands="10"
                                                segs="0"                   
                                                hi-color="rgba(255,255,255,1)"
                                                lo-color="rgba(255,255,255,1)"
                                                
                                                bar-color="rgba(255, 255, 255, 0.8)"  

                                                thickness="2"
                                                grow="2" 
                                                grow-radius="6"   
                                                back-color="rgba(255,255,255,0)" 
                                                back-outline-color="{HIGHLIGHT}" 
                                                front-color="rgb(255, 255, 255)" 
                                                front-outline-color="rgba(0, 162, 255, 0)"

                                                visibility="1" />  


                        
                        </container>

                        <!-- 顶部开关 -->
                        <container name="open"  width="20%"  height="auto" orientation="horizonal" anchor="top,right" margin-right="5%">

                                <!-- 全屏 -->
                                <button background="images/dark_Fullscreen.png"
                                        command="mm://${Fullscreen}"
                                        width="40%"
                                        aspect-ratio="1.0"/>

                                <!-- 关闭悬浮窗 -->
                                <button background="images/dark_Closeflowin.png"
                                        command="mm://${Floating Lyric}"
                                        margin-left="20%" 
                                        width="40%"
                                        aspect-ratio="1.0"/>


                        </container>

                </container>


                <!-- 播放进度条 -->
               <seekbar width="80%"
                        height="5%"
                        track-height="12"
                        thumb-radius="10"
                        thumb-color="rgba(255,255,255,0.8)"
                        foreground-color="rgba(255,255,255,0.8)"
                        background-color="rgba(255,255,255,0.2)"
                        radius="6"
                        always-show-thumb="false"
                        show-lyric-tooltip="true"
                        free-seek="1"
                        tooltip-padding="6"/>


                <container name="Ctrl"  width="100%" height="20%" orientation="horizonal">
                
                        <!-- 播放按钮 通用数值 -->
                        <props  id="play" 
                                width="16%"
                                aspect-ratio="1.0"/>

                        <!-- 上一曲按钮 -->
                        <button props="play"
                                background="images/previous.png"
                                command="esl://Previous"
                                margin-right="3%"/>

                        <!-- 播放/暂停按钮 -->
                        <button props="play"
                                background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                                command="esl://PlayOrPause"/>

                        <!-- 下一曲按钮 -->
                        <button props="play"
                                background="images/next.png"
                                command="esl://Next"
                                margin-left="3%"/>
                        
                </container>

                
                
                <!-- 歌词面板 -->
                 <lyric width="88%"
                        height="*"
                        hide-empty="1"
                        visibility="0"/>

  </panel>


</layout>