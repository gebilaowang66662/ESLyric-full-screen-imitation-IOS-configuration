<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel layout="free" name="Mini 3.2" features="1" >

        <!-- 悬浮提示 -->
        <tooltip background-color= "rgba(255,255,255,0.1)"
                text-color="rgb(0,0,0)"
                font-size="10"/>


        <!-- 白色背景 -->
        <image background="images/background_white.png"
              anchor="right"
              width="65%"
              height="100%"/>


        <!-- 顶部开关 -->
        <container name="open"  width="12%"  height="18%" orientation="horizonal" anchor="top,right" margin-right="1%">

          <!-- 全屏 -->
          <button background="images/dark_Fullscreen.png"
                  command="mm://${Fullscreen}"
                  width="40%"
                  aspect-ratio="1.0"/>

          <!-- 关闭悬浮窗 -->
          <button background="images/dark_Closeflowin.png"
                  command="mm://${Floating Lyric}"
                  margin-left="10%"
                  width="40%"
                  aspect-ratio="1.0"/>


        </container>


    <container name="text"  width="100%" height="100%"  orientation="horizonal">
        
        <container name="text"  width="60%" height="100%" >
          <!--  歌曲标题标签 
                          font-size 字号推荐大小
                          2K:  || 1080P:  || 720P:  -->
         <label name="title"
                caption="%title%"
                text-align="left"
                margin-top="10%"
                text-color="rgb(255,255,255)"
                highlight-color="rgb(255,255,255)"
                font-size="20"
                width="80%"
                height="auto"
                loop="cycle"
                command="lib://%%album%% IS %album%"/>

          <!--  歌手标签 
                          font-size 字号推荐大小
                          2K:  || 1080P:  || 720P:   -->
         <label name="artist"
                margin-top="10%"
                caption="[%artist%]"
                text-align="left"
                text-color="rgba(255,255,255,0.5)"
                highlight-color="rgb(255,255,255)"
                font-size="18"
                width="80%"
                height="auto"
                loop="cycle"
                command="lib://%artist%"/>


          <container name="Ctrl"  width="50%" height="30%" orientation="horizonal"  anchor="left" margin-left="10%" margin-top="20%">
            
                                        <!-- 播放按钮 通用数值 -->
                                        <props  id="play" 
                                                width="32%"
                                                aspect-ratio="1.0"/>  

                                        <!-- 上一曲按钮 -->
                                        <button props="play"
                                                background="images/previous.png"
                                                command="esl://Previous"
                                                margin-right="2%"/>

                                        <!-- 播放/暂停按钮 -->
                                        <button props="play"
                                                background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                                                command="esl://PlayOrPause"/>

                                        <!-- 下一曲按钮 -->
                                        <button props="play"
                                                background="images/next.png"
                                                command="esl://Next"
                                                margin-left="2%"/>

          </container>

       </container>


      <!-- 专辑封面容器 -->
      <container name="albumart"  width="40%" height="100%" layout="free" >


            <!-- 魔法阵组 -->
            <container name="albumart"  width="100%" height="100%" layout="free" visibility="1">


              <!-- 魔法阵 -->
              <albumart width="100%"
                        aspect-ratio="1.0"
                        radius="10"
                        rotate-speed="-1"
                        stub="images/default.png"
                        use-stub="false"
                        follow-background="1"
                        shadow="1"
                        shadow-color="rgba(0,0,0,0.5)"
                        shadow-intensity="10"
                        mask="images/magic circle.png"
                        rotate="1"
                        visibility="1"/>
              
              
              <!-- 专辑封面 -->
              <albumart width="55%"
                        aspect-ratio="1.0"
                        radius="10"
                        rotate-speed="0"
                        stub="images/default.png"
                        use-stub="false"
                        follow-background="1"
                        shadow="1"
                        shadow-color="rgba(0,0,0,0.8)"
                        shadow-intensity="10"
                        mask="images/Record.png"
                        rotate="1"/>

            </container>
            

      </container>

      
    </container>

        
        <!-- 歌词面板 -->
       <lyric width="88%"
              height="*"
              hide-empty="1"
              visibility="0"/>

  </panel>


</layout>