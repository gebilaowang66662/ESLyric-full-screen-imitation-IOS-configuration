<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel layout="stack" name="Horizontal and Vertical No control" orientation="horizontal" features="1">


      
          <!-- 专辑封面容器 -->
    
            <container name="albumart" width="100%" height="*" visibility="$ifequal(%esl_has_playing_lyric%,1,0,1)" layout="free">

              <!-- 专辑封面阴影 -->

              <button background="images/Cover Shadow.png"
                      min-width="1" 
                      max-width="550"
                      width="89%" 
                      aspect-ratio="1.0" />
              
              
              <!-- 专辑封面 -->
              <albumart width="80%"  
                        min-width="1" 
                        max-width="500" 
                        aspect-ratio="1.0"
                        stub="images/default.png" 
                        radius="20" use-stub="false" 
                        follow-background="1"/>
              
              
            </container>

          


        <!-- 右侧面板 -->
        <container name="right-panel" anchor="vfill" width="*" hide-empty="1">

          <!-- 歌词面板 -->
               <lyric width="80%" 
                      height="auto" 
                      anchor="vfill" 
                      hide-empty="1"/>
          
          
        </container>
    
    
  </panel>
  
  
</layout>