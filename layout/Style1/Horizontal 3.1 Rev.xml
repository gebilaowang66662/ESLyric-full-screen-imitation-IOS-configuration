<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel layout="stack" name="Horizontal 3.1 Rev"  features="1">

                <!-- 悬浮提示 -->
                <tooltip background-color= "rgba(255,255,255,0.1)"
                        font-size="10"/>


                <!-- 上侧面板 -->
                <container name="top-panel" width="100%" height="85%" layout="free" >

                        <!-- 
                        频谱 三种形态
                        classic/simple-bar/wave
                        -->
                        <visualization  type="spectrum"
                                        width="100%"
                                        height="10%"
                                        anchor="bottom"

                                        spectrum="wave"

                                        mirror="0"              
                                        bands="500"
                                        segs="0"                   
                                        hi-color="rgba(255,255,255,0.2)"
                                        lo-color="rgba(255,255,255,1)"
                                        
                                        bar-color="rgba(255, 255, 255, 0.8)"  

                                        thickness="2"
                                        grow="2" 
                                        grow-radius="6"   
                                        back-color="rgba(255, 255, 255, 0)" 
                                        back-outline-color="rgb(255, 255, 255)" 
                                        front-color="rgba(255, 255, 255, 0)" 
                                        front-outline-color="rgb(4, 155, 249)"

                                        visibility="1" /> 
                
                        <!-- 上侧面板 -->
                        <container name="top-panel" width="100%" height="100%" orientation="horizontal" >

                                <!-- 左侧面板 -->
                                <container name="right-panel" anchor="vfill" width="*" hide-empty="1">

                                        <!-- 歌词面板 -->
                                        <lyric  width="90%"
                                                height="auto"
                                                anchor="vfill"
                                                hide-empty="1"/>


                                </container>
                        
                                <!-- 右侧面板 -->
                                <container name="left-panel"  anchor="vfill" width="45%">


                                        <!-- 专辑封面容器 -->

                                        <container name="albumart" width="80%" height="72%" layout="free">



                                                        <!-- 封底 2-->
                                                      <albumart width="72%"
                                                                height="72%"
                                                                margin-left="14%"
                                                                margin-bottom="1%"
                                                                album-art="front"
                                                                stub="images/default.png"
                                                                radius="20"
                                                                use-stub="false"
                                                                shadow="1"
                                                                shadow-color="rgba(0,0,0,0.8)"
                                                                shadow-intensity="10"
                                                                follow-background="1"
                                                                mask="images/Cover Shadow.png"
                                                                visibility="1"/>


                                                        <!-- 碟面 2-->
                                                      <albumart width="auto"
                                                                height="70%"
                                                                margin-left="12%"
                                                                aspect-ratio="1.0"
                                                                album-art="disc"
                                                                radius="10"
                                                                rotate-speed="1"
                                                                stub="images/default.png"
                                                                use-stub="false"
                                                                follow-background="1"
                                                                shadow="1"
                                                                shadow-color="rgba(0,0,0,0.8)"
                                                                shadow-intensity="10"
                                                                mask="images/Record 2.png"
                                                                rotate="1"
                                                                visibility="1"/>


                                                        <!-- 封面 2-->
                                                      <albumart width="70%"
                                                                height="70%"
                                                                anchor="left"
                                                                margin-left="3%"
                                                                album-art="back"
                                                                stub="images/default.png"
                                                                radius="20"
                                                                use-stub="false"
                                                                mask="images/albumart mask.png"
                                                                shadow="1"
                                                                shadow-color="rgba(0,0,0,0.8)"
                                                                shadow-intensity="10"
                                                                follow-background="1"
                                                                visibility="1"/>


                                        </container>

                                                <!-- 歌曲信息标签容器 -->
                                                <container name="meta-info"  width="80%" height="10%" orientation="horizonal">

                                                        <!-- 歌曲歌手标签 -->
                                                        <container name="info" width="87%" height="100%" >

                                                                <!--  歌曲标题标签 
                                                                        font-size 字号推荐大小
                                                                        2K:  || 1080P:  || 720P:  -->
                                                                 <label name="title"
                                                                        caption="%title%"
                                                                        text-color="rgb(255,255,255)"
                                                                        font-size="23"
                                                                        width="100%"
                                                                        height="auto"
                                                                        loop="cycle" 
                                                                        command="lib://%%album%% IS %album%"/>

                                                                <!--  歌手标签 
                                                                        font-size 字号推荐大小
                                                                        2K:  || 1080P:  || 720P:   -->
                                                                 <label name="artist"
                                                                        margin-top="14%"
                                                                        caption="[%artist%] - %album%"
                                                                        text-color="rgba(255,255,255,0.5)"
                                                                        font-size="20"
                                                                        width="100%"
                                                                        height="auto"
                                                                        loop="cycle"
                                                                        command="lib://%artist%"/>


                                                        </container>

                                                </container>

                                        </container>


                                </container>
                        
                        
                        
                        </container>

                <!-- 下侧面板 -->
                <container name="bottom-panel" width="100%" height="15%" justify="start" >



                                <!-- 播放进度条 
                                track-height thumb-radius(同)推荐大小
                                2K:  || 1080P:  || 720P:   -->
                               <seekbar width="100%"
                                        height="8%"
                                        track-height="16"
                                        thumb-color="rgba(255,255,255,0.8)"
                                        foreground-color="rgba(255,255,255,0.8)"
                                        background-color="rgba(255,255,255,0.1)"
                                        always-show-thumb="false"
                                        show-lyric-tooltip="true"
                                        free-seek="1"
                                        tooltip-padding="6"/>

                                <!-- 当前播放时间 
                                        font-size 字号推荐大小
                                        2K:  || 1080P:  || 720P:   -->
                                 <label name="playback_time"
                                        caption="%playback_time%  /  -%playback_time_remaining%"
                                        text-align="right"
                                        text-color="rgba(255,255,255,0.8)"
                                        font-size="18"
                                        width="auto"
                                        height="20%"
                                        anchor="right"
                                        margin-right="1%"/>


                                <!-- 控制按钮组 -->
                                <container name="ctrl" layout="free"  width="100%" height="50%" >

                                                <!-- 音量按钮 通用数值 -->
                                                <props  id="volume" 
                                                        command="esl://Mute"
                                                        anchor="left"
                                                        margin-left="1%"
                                                        width="2%"
                                                        aspect-ratio="1.0"/>

                                                <!-- 音量 -->
                                                <button props="volume" 
                                                        background="images/volume+.png"
                                                        visibility="$ifequal(%fb2k_volume_level_5%,0,0,1)"/>

                                                <button props="volume" 
                                                        background="images/Mute.png"
                                                        visibility="$ifequal(%fb2k_volume_level_5%,0,1,0)"/>

                                                <!-- 音量条 
                                                track-height thumb-radius(同)推荐大小
                                                2K:  || 1080P:  || 720P:   -->
                                                <volume width="8%"
                                                        height="100%"
                                                        anchor="left"
                                                        margin-left="3%"
                                                        track-height="7"
                                                        thumb-radius="7"
                                                        margin-right="28%"
                                                        thumb-color="rgba(255,255,255,0.8)"
                                                        foreground-color="rgba(255,255,255,0.8)"
                                                        background-color="rgba(255,255,255,0.2)"
                                                        radius="4"
                                                        always-show-thumb="false"/>


                                                <!-- 随机模式按钮 通用数据-->
                                                <props  id="Random" 
                                                        width="4%"
                                                        aspect-ratio="1.0"
                                                        margin-right="10%"/>

                                                <!-- 随机播放/默认模式切换按钮 -->
                                                <button props="Random" 
                                                        background="$if($or($ifequal(%fb2k_playback_order%,3,1,0),$ifequal(%fb2k_playback_order%,4,1,0),$ifequal(%fb2k_playback_order%,5,1,0)),images/Random.png,images/Random_Close.png)"
                                                        command="esl://PlaybackOrderShuffleTracks"
                                                        visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,1,1,$ifequal(%fb2k_playback_order%,2,1,0)))"/>

                                                <button props="Random" 
                                                        background="images/Random.png"
                                                        command="esl://PlaybackOrderDefault"
                                                        visibility="$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0))))"/>


                                                <!-- 播放按钮 通用数值 -->
                                                <props  id="play" 
                                                        width="4%"
                                                        aspect-ratio="1.0"/>

                                                <!-- 上一曲按钮 -->
                                                <button props="play" 
                                                        background="images/previous.png"
                                                        command="esl://Previous"
                                                        margin-right="5%"/>

                                                <!-- 播放/暂停按钮 -->
                                                <button props="play" 
                                                        background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                                                        command="esl://PlayOrPause"/>

                                                <!-- 下一曲按钮 -->
                                                <button props="play" 
                                                        background="images/next.png"
                                                        command="esl://Next"
                                                        margin-left="5%"/>


                                                <!-- 循环按钮 通用数值 -->
                                                <props  id="cycling" 
                                                        width="4%"
                                                        aspect-ratio="1.0"
                                                        margin-left="10%"/>

                                                <!-- 循环模式按钮 -->
                                                <button props="cycling" 
                                                        background="$if($or($ifequal(%fb2k_playback_order%,0,1,0),$ifequal(%fb2k_playback_order%,1,1,0),$ifequal(%fb2k_playback_order%,2,1,0)),images/Single loop.png,images/cycling_Close.png)"
                                                        command="esl://PlaybackOrderRepeatPlaylist"
                                                        visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0)))))"/>

                                                <button props="cycling" 
                                                        background="images/cycling.png"
                                                        command="esl://PlaybackOrderRepeatTrack"
                                                        visibility="$ifequal(%fb2k_playback_order%,1,1,0)"/>

                                                <button props="cycling" 
                                                        background="images/Single loop.png"
                                                        command="esl://PlaybackOrderDefault"
                                                        visibility="$ifequal(%fb2k_playback_order%,2,1,0)"/>
                                        
                                        <!-- 歌词开关 
                                        根据是否有歌词显示按钮
                                        The condition used to determine the button’s visibility based on whether lyrics are present is:
                                        
                                        visibility="$ifequal(%esl_has_playing_lyric%,1,1,0)"

                                        始终显示
                                        always show the button:

                                        visibility="0"
                                        -->
                                        <button background="images/lyric.png"
                                                command="mm://${lyric}"
                                                margin-right="5%"
                                                anchor="right"
                                                width="2%"
                                                aspect-ratio="1.0"
                                                visibility="0"/>

                                        <!-- 当前播放音轨属性按钮 -->
                                        <button background="images/Properties1.png"
                                                command="esl://Properties"
                                                anchor="right"
                                                margin-right="1%"
                                                width="3%"
                                                aspect-ratio="1.0" />

                                </container>
                
                
                </container>

  </panel>


</layout>