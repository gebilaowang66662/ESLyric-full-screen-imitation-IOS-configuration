<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel layout="stack" name="Bottom bar" orientation="horizonal" features="1">

                <!-- 悬浮提示 -->
                <tooltip background-color= "rgba(255,255,255,0.1)"
                         font-size="10"/>

                        <!-- 专辑封面 -->
                        <container name="albumart"  width="30%" height="100%" orientation="horizonal" >
                        
                              <albumart width="auto"
                                        height="85%"
                                        aspect-ratio="1.0"
                                        margin-left="2%"
                                        stub="images/default.png"
                                        radius="6"
                                        use-stub="false"
                                        follow-background="1"
                                        shadow="1"
                                        shadow-color="rgba(0,0,0,0.5)"
                                        shadow-intensity="5"/>
                                        
                                
                                <!-- 歌曲歌手标签 -->
                                <container name="info"  width="*" height="100%"  >

                                        <!--  歌曲标题标签 
                                                        font-size 字号推荐大小
                                                        2K:  || 1080P:  || 720P:  -->
                                        <label  name="title"
                                                caption="%title%"
                                                anchor="left"
                                                margin-left="4%"
                                                text-color="rgb(255,255,255)"
                                                font-size="16"
                                                width="auto"
                                                height="auto"
                                                loop="cycle"
                                                command="lib://%%album%% IS %album%"/>

                                        <!--  歌手标签 
                                                        font-size 字号推荐大小
                                                        2K:  || 1080P:  || 720P:   -->
                                        <label  name="artist"
                                                margin-top="10%"
                                                caption="[%artist%]"
                                                anchor="left"
                                                margin-left="4%"
                                                text-color="rgba(255,255,255,0.5)"
                                                font-size="14"
                                                width="auto"
                                                height="auto"
                                                loop="cycle"
                                                command="lib://%artist%"/>


                                </container>
                        
                        </container>

                        <!-- 中间歌词容器容器 visibility禁用！-->
                        <container name="middle-panel"  height="100%" width="20%" hide-empty="1" visibility="0">

                                <!-- 歌词面板 -->
                                <lyric  width="100%"
                                        height="auto"
                                        anchor="vfill"
                                        hide-empty="1"/>


                        </container>


                        <!-- 控制按钮组 -->
                        <container name="Ctrl" width="40%" height="100%" justify="start">

                                <!-- 控制按钮 -->
                                <container name="ctrl" orientation="horizontal"  width="100%" height="65%" >

                                        <!-- 随机模式按钮 通用数据-->
                                        <props  id="Random" 
                                                width="auto"
                                                height="90%"
                                                aspect-ratio="1.0"
                                                margin-right="1%"/>
                                                
                                        <!-- 随机播放/默认模式切换按钮 -->
                                        <button props="Random"
                                                background="$if($or($ifequal(%fb2k_playback_order%,3,1,0),$ifequal(%fb2k_playback_order%,4,1,0),$ifequal(%fb2k_playback_order%,5,1,0)),images/Random.png,images/Random_Close.png)"
                                                command="esl://PlaybackOrderShuffleTracks"
                                                visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,1,1,$ifequal(%fb2k_playback_order%,2,1,0)))"/>

                                        <button props="Random"
                                                background="images/Random.png"
                                                command="esl://PlaybackOrderDefault"
                                                visibility="$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0))))"/>

                                        <!-- 播放按钮 通用数值 -->
                                        <props  id="play" 
                                                width="auto"
                                                height="90%"
                                                aspect-ratio="1.0"/>

                                        <!-- 上一曲按钮 -->
                                        <button props="play"
                                                background="images/previous.png"
                                                command="esl://Previous"
                                                margin-right="1%"/>

                                        <!-- 播放/暂停按钮 -->
                                        <button props="play"
                                                background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                                                command="esl://PlayOrPause"/>

                                        <!-- 下一曲按钮 -->
                                        <button props="play"
                                                background="images/next.png"
                                                command="esl://Next"
                                                margin-left="1%"/>


                                        <!-- 循环模式按钮 通用数据-->
                                        <props  id="cycling" 
                                                width="auto"
                                                height="90%"
                                                aspect-ratio="1.0"
                                                margin-left="1%"/>

                                        <!-- 循环模式按钮 -->
                                        <button props="cycling"
                                                background="$if($or($ifequal(%fb2k_playback_order%,0,1,0),$ifequal(%fb2k_playback_order%,1,1,0),$ifequal(%fb2k_playback_order%,2,1,0)),images/Single loop.png,images/cycling_Close.png)"
                                                command="esl://PlaybackOrderRepeatPlaylist"
                                                visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0)))))"/>

                                        <button props="cycling"
                                                background="images/cycling.png"
                                                command="esl://PlaybackOrderRepeatTrack"
                                                visibility="$ifequal(%fb2k_playback_order%,1,1,0)"/>

                                        <button props="cycling"
                                                background="images/Single loop.png"
                                                command="esl://PlaybackOrderDefault"
                                                visibility="$ifequal(%fb2k_playback_order%,2,1,0)"/>


                                </container>


                                <!-- 播放进度条容器 -->
                                <container name="Ctrl"  width="100%" height="20%" orientation="horizonal">

                                        <!-- 当前播放时间 
                                        font-size 字号推荐大小
                                        2K:  || 1080P:  || 720P:   -->
                                        <label  name="playback_time"
                                                caption="%playback_time%"
                                                text-align="right"
                                                text-color="rgba(255,255,255,0.3)"
                                                font-size="14"
                                                width="15%"
                                                height="auto" />

                                        <!-- 播放进度条 -->
                                       <seekbar width="*"
                                                height="*"
                                                track-height="6"
                                                thumb-radius="6"
                                                thumb-color="rgba(255,255,255,0.8)"
                                                foreground-color="rgba(255,255,255,0.8)"
                                                background-color="rgba(255,255,255,0.2)"
                                                radius="4"
                                                always-show-thumb="false"
                                                show-lyric-tooltip="true"
                                                free-seek="1"
                                                tooltip-padding="6"/>

                                        <!-- 剩余播放时间 
                                        font-size 字号推荐大小
                                        2K:  || 1080P:  || 720P:   -->
                                        <label  name="playback_time_remaining"
                                                caption="-%playback_time_remaining%"
                                                text-align="left"
                                                text-color="rgba(255,255,255,0.3)"
                                                font-size="14"
                                                width="15%"
                                                height="auto" />


                                </container>



                        </container>


                        <!-- 音量控制容器 -->
                        <container name="Volume" justify="end" width="30%" height="100%" orientation="horizonal">

                                <!-- 设备 -->
                                <button background="images/device.png"
                                        command="mm://${device}"
                                        margin-right="3%"
                                        width="auto"
                                        height="25%"
                                        aspect-ratio="1.0"/>

                                <!-- 打开迷你悬浮窗 -->
                                <button background="images/Showflowin.png"
                                        command="mm://${Floating Lyric}"
                                        margin-right="3%"
                                        width="auto"
                                        height="30%"
                                        aspect-ratio="1.0"/>


                                <!-- 音量-按钮 通用数值 -->
                                <props  id="volume" 
                                        command="esl://Mute"
                                        margin-right="2%"
                                        width="auto"
                                        height="30%"
                                        aspect-ratio="1.0"/>

                                <!-- 静音 -->
                                <button props="volume"
                                        background="images/volume+.png"
                                        visibility="$ifequal(%fb2k_volume_level_5%,0,0,1)"/>

                                <button props="volume"
                                        background="images/Mute.png"
                                        visibility="$ifequal(%fb2k_volume_level_5%,0,1,0)"/>

                                <!-- 音量条 -->
                                <volume width="auto"
                                        height="120%"
                                        aspect-ratio="1.0"
                                        margin-right="3%"
                                        track-height="6"
                                        thumb-radius="6"
                                        foreground-color="rgba(255,255,255,0.8)"
                                        background-color="rgba(255,255,255,0.2)"
                                        radius="4"
                                        always-show-thumb="false"/>

                                <!-- 全屏 -->
                                <button background="images/Fullscreen.png"
                                        command="mm://${Fullscreen}"
                                        margin-right="5%"
                                        width="auto"
                                        height="25%"
                                        aspect-ratio="1.0"/>

                        </container>


  </panel>


</layout>