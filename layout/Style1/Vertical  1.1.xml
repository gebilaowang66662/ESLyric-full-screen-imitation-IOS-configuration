<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./../Layout.xsd">

<!-- ======= Foobar2000 ESLyric Layout File ======== -->
<!-- 名称 / Name        : 仿 Apple Music 配置  / imitation-IOS-configuration                                  -->
<!-- 版本 / Version     : v1.6                                                                                -->
<!-- 作者 / Author      : gebilaowang66662                                                                    -->
<!-- 教程链接 / Guide   : https://github.com/gebilaowang66662/ESLyric-full-screen-imitation-IOS-configuration -->
<!-- 最后更新 / Updated : 2026-02-27                                                                          -->
<!-- =========================================== -->

  <!-- 主面板布局 -->
  <panel layout="stack" name="Vertical 1.1" orientation="vertical" features="1">

                <!-- 悬浮提示 -->
                <tooltip background-color= "rgba(255,255,255,0.1)"
                        font-size="10"/>
                
                
                <!-- 无歌词顶部容器容器 1-->
                <container name="top-panel1" width="100%" height="*" visibility="$ifequal(%esl_has_playing_lyric%,0,1,0)">

                        <!-- 专辑封面容器 -->
                        <container name="albumart"  width="100%" height="90%" layout="free">


                                        <!-- 封底 2-->
                                      <albumart width="72%"
                                                margin-left="12%"
                                                margin-bottom="1%"
                                                aspect-ratio="1.0"
                                                album-art="front"
                                                stub="images/default.png"
                                                radius="20"
                                                use-stub="false"
                                                shadow="1"
                                                shadow-color="rgba(0,0,0,0.8)"
                                                shadow-intensity="10"
                                                follow-background="1"
                                                mask="images/Cover Shadow.png"
                                                visibility="1"/>


                                        <!-- 碟面 2-->
                                      <albumart width="70%"
                                                height="auto"
                                                margin-left="12%"
                                                aspect-ratio="1.0"
                                                album-art="disc"
                                                radius="10"
                                                rotate-speed="1"
                                                stub="images/default.png"
                                                use-stub="false"
                                                follow-background="1"
                                                shadow="1"
                                                shadow-color="rgba(0,0,0,0.8)"
                                                shadow-intensity="10"
                                                mask="images/Record 2.png"
                                                rotate="1"
                                                visibility="1"/>


                                        <!-- 封面 2-->
                                      <albumart width="70%"
                                                anchor="left"
                                                margin-left="4%"
                                                aspect-ratio="1.0"
                                                album-art="back"
                                                stub="images/default.png"
                                                radius="20"
                                                use-stub="false"
                                                mask="images/albumart mask.png"
                                                shadow="1"
                                                shadow-color="rgba(0,0,0,0.8)"
                                                shadow-intensity="10"
                                                follow-background="1"
                                                visibility="1"/>


                        </container>

                        <!-- 歌曲信息标签容器 -->
                        <container name="meta-info" width="86%" height="10%" orientation="horizonal">

                                <!-- 歌曲歌手标签 -->
                                <container name="info" width="86%" height="100%" >

                                        <!--  歌曲标题标签 
                                                font-size 字号推荐大小
                                                2K:  || 1080P:  || 720P:  -->
                                         <label name="title"
                                                caption="%title%"
                                                text-align="left"
                                                text-color="rgb(255,255,255)"
                                                font-size="20"
                                                width="100%"
                                                height="auto"
                                                loop="cycle"
                                                command="lib://%%album%% IS %album%"/>

                                        <!--  歌手标签 
                                                font-size 字号推荐大小
                                                2K:  || 1080P:  || 720P:   -->
                                         <label name="artist"
                                                margin-top="14%"
                                                caption="[%artist%]"
                                                text-align="left"
                                                text-color="rgba(255,255,255,0.5)"
                                                font-size="16"
                                                width="100%"
                                                height="auto"
                                                loop="cycle"
                                                command="lib://%artist%"/>


                                </container>

                                <!-- 当前播放音轨属性按钮容器 -->
                                <container name="Properties" width="14%" height="100%" >

                                        <!-- 当前播放音轨属性按钮 -->
                                        <button background="images/Properties.png"
                                                command="esl://Properties"
                                                anchor="right"
                                                width="80%"
                                                aspect-ratio="1.0" />

                                </container>


                        </container>


                </container>



                <!-- 有歌词顶部容器容器 2-->
                <container name="top-panel2" width="88%"  height="12%" orientation="horizonal" visibility="%esl_has_playing_lyric%" >

                        <!-- 专辑封面容器 -->
                        <container name="albumart" anchor="center" width="22%" height="100%" layout="free">


                                <!-- 专辑封面 -->
                              <albumart width="90%"
                                        aspect-ratio="1.0"
                                        stub="images/default.png"
                                        radius="10"
                                        use-stub="false"
                                        follow-background="1"
                                        shadow="1"
                                        shadow-color="rgba(0,0,0,0.8)"
                                        shadow-intensity="5"/>


                        </container>


                        <container name="meta-info" width="78%" height="100%" orientation="horizonal">

                                <!-- 歌曲歌手标签 -->
                                <container name="info" width="85%" height="100%" >

                                        <!--  歌曲标题标签 
                                                font-size 字号推荐大小
                                                2K:  || 1080P:  || 720P:  -->
                                         <label name="title"
                                                caption="%title%"
                                                text-align="left"
                                                text-color="rgb(255,255,255)"
                                                font-size="20"
                                                width="90%"
                                                height="auto"
                                                loop="cycle"
                                                command="lib://%%album%% IS %album%" />

                                        <!--  歌手标签 
                                                font-size 字号推荐大小
                                                2K:  || 1080P:  || 720P:   -->
                                         <label name="artist"
                                                margin-top="5%"
                                                caption="[%artist%]"
                                                text-align="left"
                                                text-color="rgba(255,255,255,0.5)"
                                                font-size="16"
                                                width="90%"
                                                height="auto"
                                                loop="cycle"
                                                command="lib://%artist%"/>


                                </container>

                                <!-- 当前播放音轨属性按钮容器 -->
                                <container name="Properties" width="15%" height="100%" >

                                        <!-- 当前播放音轨属性按钮 -->
                                        <button background="images/Properties.png"
                                                command="esl://Properties"
                                                width="90%"
                                                aspect-ratio="1.0" />


                                </container>


                        </container>


                </container>


                <!-- 中间歌词面板 -->
                <lyric width="88%"
                        height="*"
                        hide-empty="1"/>


                <!-- 底部组件容器 -->
                <container name="bottom-panel" width="100%" height="26%">

                        <!-- 播放进度条 
                                track-height thumb-radius(同)推荐大小
                                2K:  || 1080P:  || 720P:   -->
                      <seekbar width="93%"
                                height="15%"
                                track-height="8"
                                thumb-radius="8"
                                thumb-color="rgba(255,255,255,0.8)"
                                foreground-color="rgba(255,255,255,0.8)"
                                background-color="rgba(255,255,255,0.2)"
                                radius="4"
                                always-show-thumb="false"
                                show-lyric-tooltip="true" 
                                free-seek="1"
                                tooltip-padding="6"/>

                        <!-- 播放时间显示 -->
                        <container name="length" orientation="horizontal" width="88%" height="auto" >

                                <!-- 当前播放时间 
                                font-size 字号推荐大小
                                2K:  || 1080P:  || 720P:   -->
                                 <label name="playback_time"
                                        caption="%playback_time%"
                                        text-align="left"
                                        text-color="rgba(255,255,255,0.3)"
                                        font-size="18"
                                        width="50%"
                                        height="auto" />

                                <!-- 剩余播放时间 
                                font-size 字号推荐大小
                                2K:  || 1080P:  || 720P:   -->
                                 <label name="playback_time_remaining"
                                        caption="-%playback_time_remaining%"
                                        text-align="right"
                                        text-color="rgba(255,255,255,0.3)"
                                        font-size="18"
                                        width="50%"
                                        height="auto" />


                        </container>


                        <!-- 控制按钮组 -->
                        <container name="ctrl" orientation="horizontal" width="97%" height="30%" >

                                <!-- 随机模式按钮 通用数据-->
                                <props  id="Random" 
                                        width="14%"
                                        aspect-ratio="1.0"
                                        margin-right="4%"/>

                                <!-- 随机播放/默认模式切换按钮 -->
                                <button props="Random"
                                        background="$if($or($ifequal(%fb2k_playback_order%,3,1,0),$ifequal(%fb2k_playback_order%,4,1,0),$ifequal(%fb2k_playback_order%,5,1,0)),images/Random.png,images/Random_Close.png)"
                                        command="esl://PlaybackOrderShuffleTracks"
                                        visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,1,1,$ifequal(%fb2k_playback_order%,2,1,0)))"/>

                                <button props="Random"
                                        background="images/Random.png"
                                        command="esl://PlaybackOrderDefault"
                                        visibility="$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0))))"/>

                                <!-- 播放按钮 通用数值 -->
                                <props  id="play" 
                                        width="18%"
                                        aspect-ratio="1.0"/>

                                <!-- 上一曲按钮 -->
                                <button props="play"
                                        background="images/previous.png"
                                        command="esl://Previous"
                                        margin-right="4%"/>

                                <!-- 播放/暂停按钮 -->
                                <button props="play"
                                        background="$if($or($not(%isplaying%), %ispaused%),images/play.png,images/pause.png)"
                                        command="esl://PlayOrPause"/>

                                <!-- 下一曲按钮 -->
                                <button props="play"
                                        background="images/next.png"
                                        command="esl://Next"
                                        margin-left="4%"/>

                                <!-- 循环模式按钮 通用数据-->
                                <props  id="cycling" 
                                        width="14%"
                                        aspect-ratio="1.0"
                                        margin-left="4%"/>

                                <!-- 循环模式按钮 -->
                                <button props="cycling"
                                        background="$if($or($ifequal(%fb2k_playback_order%,0,1,0),$ifequal(%fb2k_playback_order%,1,1,0),$ifequal(%fb2k_playback_order%,2,1,0)),images/Single loop.png,images/cycling_Close.png)"
                                        command="esl://PlaybackOrderRepeatPlaylist"
                                        visibility="$ifequal(%fb2k_playback_order%,0,1,$ifequal(%fb2k_playback_order%,3,1,$ifequal(%fb2k_playback_order%,4,1,$ifequal(%fb2k_playback_order%,5,1,$ifequal(%fb2k_playback_order%,6,1,0)))))"/>

                                <button props="cycling"
                                        background="images/cycling.png"
                                        command="esl://PlaybackOrderRepeatTrack"
                                        visibility="$ifequal(%fb2k_playback_order%,1,1,0)"/>

                                <button props="cycling"
                                        background="images/Single loop.png"
                                        command="esl://PlaybackOrderDefault"
                                        visibility="$ifequal(%fb2k_playback_order%,2,1,0)"/>


                        </container>

                        <!-- 音量控制 -->
                        <container name="volume" orientation="horizontal" width="88%" height="20%" >

                                <!-- 音量-按钮 通用数值 -->
                                <props  id="volume" 
                                        command="esl://Mute"
                                        width="10%"
                                        aspect-ratio="1.0"/>

                                <!-- 音量- -->
                                <button props="volume"
                                        background="images/volume-.png"
                                        visibility="$ifequal(%fb2k_volume_level_5%,0,0,1)"/>

                                <button props="volume"
                                        background="images/Mute.png"
                                        visibility="$ifequal(%fb2k_volume_level_5%,0,1,0)"/>

                                <!-- 音量条 
                                track-height thumb-radius(同)推荐大小
                                2K:  || 1080P:  || 720P:   -->
                                <volume width="*"
                                        height="100%"
                                        track-height="8"
                                        thumb-radius="8"
                                        thumb-color="rgba(255,255,255,0.8)"
                                        foreground-color="rgba(255,255,255,0.8)"
                                        background-color="rgba(255,255,255,0.2)"
                                        radius="4"
                                        always-show-thumb="false"/>

                                <!-- 音量+ -->
                                <button background="images/volume+.png"
                                        command="mm://${VolumeUp}"
                                        width="10%"
                                        aspect-ratio="1.0"/>


                        </container>

                        <container name="ctrl" layout="free" width="97%" height="15%" >
                                <!-- 设备 -->
                                <button background="images/device.png"
                                        command="mm://${device}"
                                        margin-left="4%"
                                        anchor="left"
                                        width="8%"
                                        aspect-ratio="1.0"/>

                                <!-- 打开迷你悬浮窗 -->
                                <button background="images/Showflowin.png"
                                        command="mm://${Floating Lyric}"
                                        margin-right="4%"
                                        anchor="right"
                                        width="10%"
                                        aspect-ratio="1.0"/>

                        </container>

                </container>


  </panel>


</layout>